AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_KEY=<key>
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_GPT=gpt-4.1
AZURE_OPENAI_DEPLOYMENT_EMBED=text-embedding-3-large
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini   # optional: cheaper model for HyDE passage generation

COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_KEY=<your-key>
COSMOS_DB_NAME=legal-rag
COSMOS_CONTAINER_DOCUMENTS=documents

AI_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AI_SEARCH_KEY=<your-admin-key-or-query-key>
AI_SEARCH_INDEX_CHUNKS=legal-chunks

BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
BLOB_CONTAINER_NAME=legal-docs

SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<policy>;SharedAccessKey=<key>
SERVICE_BUS_QUEUE_INGESTION=ingestion-queue



# $env:PYTHONPATH = "."; venv\Scripts\python.exe workers\ingestion_worker.py